SEC_USER_AGENT="HistoricalsSolver/0.1 your-email@example.com"

# Optional SEC bulk archive cache. If these configured ZIP paths are absent,
# the server starts a background download into tmp/sec-bulk and uses live SEC
# APIs until the cache is ready.
SEC_BULK_CACHE_DIR="tmp/sec-bulk"
SEC_BULK_COMPANYFACTS_ZIP=""
SEC_BULK_SUBMISSIONS_ZIP=""
SEC_BULK_REFRESH_INTERVAL_MS="86400000"

# Optional user-verified completed-model library.
# Workbooks with "filled" in the filename are always excluded from gold-model use.
GOLD_MODEL_LIBRARY_PATH=""
GOLD_MODEL_MANIFEST_PATH=""
GOLD_MODEL_VERIFIED_PATHS=""

# Optional LLM-assisted fallback mapping.
OPENROUTER_API_KEY=""
LLM_MAPPING_ENABLED="true"
LLM_MAPPING_FAST_MODEL="openrouter/owl-alpha"
LLM_MAPPING_COMPLEX_MODEL="openai/gpt-5.5"
LLM_MAPPING_REVIEW_MODEL="openai/gpt-5.5"
LLM_MAPPING_MAX_CALLS="24"
LLM_LINE_ITEM_CLASSIFICATION_TIMEOUT_MS="30000"
LLM_MAPPING_REVIEW_TIMEOUT_MS="45000"
LLM_MAPPING_REVIEW_ENABLED="true"
LLM_MAPPING_REVIEW_MAX_ITEMS="2500"
LLM_MAPPING_REVIEW_BLOCKING="true"
LLM_MAPPING_MIN_CANDIDATE_SCORE="2"
LLM_MAPPING_CANDIDATE_LIMIT="80"
LLM_WORKBENCH_MAX_FACTS="500"
LLM_WORKBENCH_MAX_STATEMENT_ROWS="650"
LLM_WORKBENCH_MAX_WORKBOOK_CELLS="700"
LLM_WORKBENCH_MAX_AUDIT_ROWS="500"
LLM_WORKBENCH_MAX_SOURCE_LEDGER_ROWS="600"
LLM_WORKBENCH_MAX_BALANCE_ASSIGNMENTS="500"
OPENROUTER_APP_TITLE="Historicals Solver"

# Regression harness fixtures. Prefer a real gold_models.json in local env; the
# example manifest is only a shape/reference for setting up verified gold models.
GOLD_MODEL_LIBRARY_PATH=""
GOLD_MODEL_MANIFEST_PATH=""
GOLD_MODEL_VERIFIED_PATHS=""
REGRESSION_STANDARD_TEMPLATE=""
REGRESSION_FINANCIAL_TEMPLATE=""
REGRESSION_BASKET_CONFIG=""
REGRESSION_BASKET_CASES="AAPL,GOOG,NVDA,KO,PANW,LLY,INTC,MCD,PEP,CPB,IBM,RSG,DE,JEF"
REGRESSION_RESULTS_FILE=""
REGRESSION_BASELINE_OUT=""
REGRESSION_COMPARE_BASELINE=""
REGRESSION_ALLOW_MISSING_INPUTS="false"
SEC_FETCH_TIMEOUT_MS="60000"
OPENROUTER_SITE_URL="http://localhost:3000"
